{
  "name": "kube-visualizer",
  "version": "1.0.0",
  "description": "Interactive Kubernetes resource graph powered by D3 force layout and live cluster events.",
  "main": "index.js",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "kubernetes",
    "visualizer",
    "d3",
    "cluster-topology",
    "resource-graph"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "6.15.0",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "flatted@<=3.4.1": "3.4.2",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "path-to-regexp@<0.1.13": "0.1.13",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "qs@>=6.7.0 <=6.14.1": "6.14.2",
      "rollup@>=4.0.0 <4.59.0": "4.60.2"
    }
  }
}
